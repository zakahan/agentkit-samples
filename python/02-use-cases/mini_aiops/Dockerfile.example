# Example Dockerfile for deploying with local MCP server source
# The actual Dockerfile is auto-generated by AgentKit and gitignored.
# To apply these customizations, copy this file to Dockerfile and run:
#   cp Dockerfile.example Dockerfile
# Or let AgentKit generate the base Dockerfile, then add the MCP server install step.

FROM agentkit-cn-beijing.cr.volces.com/base/py-simple:python3.12-bookworm-slim-latest

ENV UV_SYSTEM_PYTHON=1 UV_COMPILE_BYTECODE=1 PYTHONUNBUFFERED=1 DOCKER_CONTAINER=1

COPY requirements.txt requirements.txt
RUN uv pip install -r requirements.txt

# Install MCP server from local source (build cluster cannot access github.com)
COPY mcp_server_ccapi /tmp/mcp_server_ccapi
RUN uv pip install /tmp/mcp_server_ccapi && rm -rf /tmp/mcp_server_ccapi

EXPOSE 8000
WORKDIR /app
COPY . .
CMD ["python", "-m", "agent"]
